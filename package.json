{
  "name": "yun-ui",
  "version": "1.0.0",
  "description": "一个现代化的 Vue 3 组件库",
  "keywords": [
    "vue",
    "vue3",
    "component",
    "ui",
    "frontend"
  ],
  "author": "Yun",
  "license": "MIT",
  "homepage": "https://github.com/yunmu/yun-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yunmu/yun-ui.git"
  },
  "bugs": {
    "url": "https://github.com/yunmu/yun-ui/issues"
  },
  "main": "dist/yun-ui.cjs.js",
  "module": "dist/yun-ui.esm.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/yun-ui.umd.js",
  "jsdelivr": "dist/yun-ui.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/yun-ui.esm.js",
      "require": "./dist/yun-ui.cjs.js"
    },
    "./dist/style.css": "./dist/style.css",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:demo": "vite build",
    "preview": "vite preview",
    "preinstall": "npx only-allow pnpm"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "dependencies": {
    "@vicons/fluent": "^0.12.0",
    "@vicons/ionicons5": "^0.12.0",
    "@vueuse/core": "^8.1.2",
    "async-validator": "^4.0.3",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@types/node": "^18.19.112",
    "@vicons/utils": "^0.1.4",
    "@vitejs/plugin-vue": "^2.2.4",
    "@vitejs/plugin-vue-jsx": "^1.3.8",
    "@vue/compiler-sfc": "^3.2.31",
    "autoprefixer": "10.4.2",
    "axios": "^0.26.1",
    "fast-glob": "^3.2.11",
    "github-markdown-css": "^4.0.0",
    "marked": "^1.1.1",
    "mitt": "^3.0.0",
    "postcss": "8.4.8",
    "prismjs": "^1.27.0",
    "sass": "1.26.10",
    "typescript": "^4.9.5",
    "vite": "^2.8.6",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-dts": "^1.7.3",
    "vite-plugin-svg-icons": "2.0.1",
    "vue": "^3.2.31",
    "vue-router": "4.0.0-beta.3"
  },
  "engines": {
    "node": ">=14",
    "pnpm": ">=6"
  }
}
